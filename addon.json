{
  "id": "neocron-graphics-pack",
  "name": "Enhanced Graphics (dgVoodoo2 + ReShade / vkBasalt)",
  "version": "0.3.0",
  "author": "Neocron Community",
  "description": "Modernizes Neocron 2's renderer. Windows native uses dgVoodoo2 (DX8/9 → D3D11) + ReShade for post-processing. Linux/macOS use vkBasalt as a Vulkan post-processing layer, since dgVoodoo2's D3D9 wrapper is incompatible with Wine/Proton's DXVK path.",
  "category": "graphics",
  "tags": ["dgvoodoo", "reshade", "vkbasalt", "directx", "vulkan", "renderer", "shaders"],
  "files": [
    { "src": "vkBasalt.conf",     "dst": "vkBasalt.conf",     "os": ["linux", "darwin"] },
    { "src": "dgVoodoo.conf",     "dst": "dgVoodoo.conf",     "os": ["windows"] },
    { "src": "ReShade.ini",       "dst": "ReShade.ini",       "os": ["windows"] },
    { "src": "ReShadePreset.ini", "dst": "ReShadePreset.ini", "os": ["windows"] }
  ],
  "fetch": [
    {
      "from": "https://github.com/dege-diosg/dgVoodoo2/releases/download/v2.87.1/dgVoodoo2_87_1.zip",
      "extract": "zip",
      "files": [
        { "src": "MS/x86/D3D8.dll", "dst": "D3D8.dll" },
        { "src": "MS/x86/D3D9.dll", "dst": "D3D9.dll" }
      ],
      "os": ["windows"]
    },
    {
      "from": "https://reshade.me/downloads/ReShade_Setup_6.7.3_Addon.exe",
      "extract": "exe",
      "files": [
        { "src": "ReShade32.dll", "dst": "dxgi.dll" }
      ],
      "os": ["windows"]
    },
    {
      "from": "https://github.com/crosire/reshade-shaders/archive/refs/heads/nvidia.tar.gz",
      "extract": "tar.gz",
      "files": [
        { "src": "reshade-shaders-nvidia/ShadersAndTextures/*.fx",  "dst": "reshade-shaders/Shaders" },
        { "src": "reshade-shaders-nvidia/ShadersAndTextures/*.fxh", "dst": "reshade-shaders/Shaders" },
        { "src": "reshade-shaders-nvidia/ShadersAndTextures/*.png", "dst": "reshade-shaders/Textures" },
        { "src": "reshade-shaders-nvidia/ShadersAndTextures/*.jpg", "dst": "reshade-shaders/Textures" },
        { "src": "reshade-shaders-nvidia/ShadersAndTextures/*.dds", "dst": "reshade-shaders/Textures" },
        { "src": "reshade-shaders-nvidia/ShadersAndTextures/*.tga", "dst": "reshade-shaders/Textures" }
      ],
      "os": ["windows"]
    }
  ],
  "wineDllOverrides": ["d3d8", "d3d9", "dxgi"],
  "envVars": {
    "linux": {
      "ENABLE_VKBASALT":      "1",
      "VKBASALT_CONFIG_FILE": "${INSTALL_DIR}/vkBasalt.conf"
    },
    "darwin": {
      "ENABLE_VKBASALT":      "1",
      "VKBASALT_CONFIG_FILE": "${INSTALL_DIR}/vkBasalt.conf"
    }
  },
  "conflicts": [],
  "requires": []
}
